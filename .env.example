# --- AI engine (Anthropic Claude) ---
# Powers Dynamic Category Discovery, Suggestion Resolution, feature aspects
# and dependency ordering. Without it the app uses deterministic heuristics.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=            # optional, defaults to a current Claude model

# --- AI engine (xAI Grok — alternative to Claude) ---
# If ANTHROPIC_API_KEY is not set, the app will use Grok as the AI backend.
# Both can be configured; Claude takes priority.
XAI_API_KEY=
XAI_MODEL=                  # optional, defaults to grok-3-mini-fast

# --- AI engine (Groq — alternative provider) ---
# Model roles are centralized in src/lib/ai-models.ts.
GROQ_API_KEY=
# Optional timeout override for long-form generation calls (milliseconds).
AI_CONTENT_REQUEST_TIMEOUT_MS=90000


# --- Clerk (auth; required only for saving packages) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase (storage of saved ProjectSpecs/packages + design-reference uploads) ---
# Create a public storage bucket named "design-references" for image uploads.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # server-side saves

# --- Cloudinary (design-reference image uploads) ---
# Find these in Cloudinary Console > Settings > API Keys.
# Keep CLOUDINARY_API_SECRET server-side; never prefix it with NEXT_PUBLIC_.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Stripe (Pro subscription paywall) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=            # recurring price for the Pro plan
STRIPE_WEBHOOK_SECRET=      # for /api/billing/webhook signature verification

# --- Git Integration ---
# A 64-character hex-encoded string (32 bytes key) for AES-256-GCM.
# Generate one using: openssl rand -hex 32
GIT_TOKEN_ENCRYPTION_KEY=

# --- GitHub OAuth (for "Push to GitHub" feature) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=       # e.g. http://localhost:3000/api/git/github/callback

# --- GitLab OAuth (for "Push to GitLab" feature) ---
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=       # e.g. http://localhost:3000/api/git/gitlab/callback
